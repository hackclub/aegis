{
  "name": "aegis",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build && find .output/server/node_modules -type l -delete 2>/dev/null; true",
    "predev": "bunx prisma generate",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "clean": "nuxt cleanup",
    "postinstall": "nuxt prepare && prisma generate",
    "db:migrate": "bunx prisma migrate dev --name init",
    "db:seed": "bunx prisma db seed",
    "db:drop": "bunx prisma migrate reset",
    "format": "prettier --write .",
    "check": "bunx nuxt typecheck",
    "lint": "eslint . --fix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/nprogress": "^0.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "eslint": "^10.2.1",
    "marked": "^18.0.2",
    "nprogress": "^0.2.0",
    "nuxt": "^4.4.2",
    "nuxt-auth-utils": "^0.5.29",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/tabler": "^1.2.33",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  },
  "packageManager": "bun@1.3.9",
  "trustedDependencies": [
    "@parcel/watcher",
    "@prisma/engines",
    "esbuild",
    "prisma",
    "unrs-resolver"
  ],
  "overrides": {
    "@aws-sdk/xml-builder": "3.972.10"
  }
}
